{
  "name": "@jentic/api-scorecard-formatter-html",
  "version": "1.10.0",
  "description": "HTML formatter for Jentic API Scorecard results.",
  "keywords": [
    "openapi",
    "jentic",
    "jairf",
    "scorecard",
    "html",
    "formatter"
  ],
  "license": "Apache-2.0",
  "author": "Jentic <hello@jentic.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jentic/jentic-api-scorecard.git",
    "directory": "packages/formatter-html"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org",
    "provenance": true,
    "tag": "latest"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/react.d.ts",
      "import": "./dist/react/react.js"
    }
  },
  "files": [
    "dist/",
    "LICENSE",
    "NOTICE",
    "README.md"
  ],
  "scripts": {
    "build": "npm run build:app && npm run build:react && npm run build:typescript",
    "build:app": "vite build",
    "build:react": "tsc -p tsconfig.react.json",
    "build:typescript": "tsc -p tsconfig.json",
    "dev": "vite",
    "clean": "rimraf dist *.tsbuildinfo",
    "prepack": "copyfiles -u 2 ../../LICENSE . && copyfiles -u 2 ../../NOTICE .",
    "postpack": "rimraf NOTICE LICENSE",
    "lint": "eslint src test",
    "lint:fix": "eslint src test --fix",
    "test": "TSX_TSCONFIG_PATH=test/tsconfig.json mocha",
    "typescript:check-types": "tsc --noEmit && tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p test/tsconfig.json"
  },
  "engines": {
    "node": ">=22.12.0 || >=20.19.0 <21.0.0"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.1",
    "@vitejs/plugin-react": "^6.0.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.3.1",
    "vite": "^8.1.0",
    "vite-plugin-singlefile": "^2.3.0"
  }
}
