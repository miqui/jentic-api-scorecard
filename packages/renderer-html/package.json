{
  "name": "@jentic/api-scorecard-renderer-html",
  "version": "1.0.0",
  "description": "HTML renderer for Jentic API Scorecard results (stub).",
  "keywords": [
    "openapi",
    "jentic",
    "jairf",
    "scorecard",
    "html"
  ],
  "license": "Apache-2.0",
  "author": "Jentic <hello@jentic.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jentic/jentic-api-scorecard.git",
    "directory": "packages/renderer-html"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org",
    "provenance": true,
    "tag": "latest"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/",
    "LICENSE",
    "NOTICE",
    "README.md"
  ],
  "scripts": {
    "build": "npm run build:typescript",
    "build:typescript": "tsc -p tsconfig.json",
    "clean": "rimraf dist *.tsbuildinfo",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "typescript:check-types": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20.10.0"
  }
}
