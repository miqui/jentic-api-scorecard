{
  "name": "@jentic/api-scorecard",
  "version": "1.0.0",
  "description": "Score an OpenAPI document against the Jentic API AI Readiness Framework (JAIRF).",
  "keywords": [
    "openapi",
    "jentic",
    "jairf",
    "scorecard",
    "ai-readiness"
  ],
  "license": "Apache-2.0",
  "author": "Jentic <hello@jentic.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jentic/jentic-api-scorecard.git",
    "directory": "packages/cli"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org",
    "provenance": true,
    "tag": "latest"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "jentic-api-scorecard": "./bin/jentic-api-scorecard.mjs"
  },
  "files": [
    "bin/",
    "dist/",
    "LICENSE",
    "NOTICE",
    "README.md"
  ],
  "scripts": {
    "build": "npm run build:typescript && npm run build:image",
    "build:typescript": "tsc -p tsconfig.json",
    "build:image": "docker build -t ghcr.io/jentic/jentic-api-scorecard:$npm_package_version ../../docker",
    "clean": "rimraf dist *.tsbuildinfo",
    "clean:image": "docker rmi ghcr.io/jentic/jentic-api-scorecard:$npm_package_version || true",
    "typescript:check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@redocly/openapi-core": "^1.30.0",
    "commander": "^14.0.0"
  },
  "engines": {
    "node": ">=20.10.0"
  }
}
