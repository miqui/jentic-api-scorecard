{
  "name": "@jentic/api-scorecard-cli",
  "version": "1.0.1",
  "description": "Score an OpenAPI document against the Jentic API AI Readiness Framework (JAIRF).",
  "keywords": [
    "api",
    "openapi",
    "jentic",
    "jairf",
    "score",
    "scorecard",
    "ai-readiness"
  ],
  "license": "Apache-2.0",
  "author": "Jentic <hello@jentic.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jentic/jentic-api-scorecard.git",
    "directory": "packages/cli"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org",
    "provenance": true,
    "tag": "latest"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "jentic-api-scorecard": "./bin/jentic-api-scorecard.mjs"
  },
  "files": [
    "bin/",
    "dist/",
    "LICENSE",
    "NOTICE",
    "README.md"
  ],
  "scripts": {
    "build": "npm run build:typescript",
    "build:typescript": "tsc -p tsconfig.json",
    "clean": "rimraf dist *.tsbuildinfo",
    "prepack": "copyfiles -u 2 ../../LICENSE . && copyfiles -u 2 ../../NOTICE . && copyfiles -u 2 ../../README.md .",
    "postpack": "rimraf NOTICE LICENSE README.md",
    "lint": "eslint src test",
    "lint:fix": "eslint src test --fix",
    "test": "mocha",
    "test:e2e": "mocha --no-config --node-option import=tsx --timeout 120000 'test/e2e/**/*.e2e.test.ts'",
    "typescript:check-types": "tsc --noEmit && tsc --noEmit -p test/tsconfig.json"
  },
  "dependencies": {
    "@redocly/openapi-core": "^2.31.6",
    "chalk": "^5.6.2",
    "commander": "^14.0.0",
    "ora": "^9.4.0",
    "strip-ansi": "^7.2.0"
  },
  "engines": {
    "node": ">=22.12.0 || >=20.19.0 <21.0.0"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "chai": "^6.2.2",
    "mocha": "^11.7.6",
    "tsx": "^4.22.3"
  }
}
