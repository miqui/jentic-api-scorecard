{
  "name": "jentic-api-scorecard-monorepo",
  "private": true,
  "version": "1.0.0-alpha.0",
  "description": "Workspace root for @jentic/api-scorecard-cli.",
  "license": "Apache-2.0",
  "author": "Jentic <hello@jentic.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jentic/jentic-api-scorecard.git"
  },
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "lerna run build",
    "build:image": "docker build -t ghcr.io/jentic/jentic-api-scorecard:$(node -p \"require('./packages/cli/package.json').version\") ./docker",
    "clean": "lerna run clean",
    "clean:image": "docker rmi ghcr.io/jentic/jentic-api-scorecard:$(node -p \"require('./packages/cli/package.json').version\") || true",
    "test": "lerna run test",
    "test:e2e": "npm run build && npm run build:image && lerna run test:e2e",
    "typescript:check-types": "lerna run typescript:check-types",
    "lint": "lerna run lint",
    "lint:fix": "lerna run lint:fix",
    "prepare": "husky"
  },
  "overrides": {
    "@conventional-changelog/git-client": {
      "conventional-commits-filter": "^3.0.0"
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@eslint/js": "^9.28.0",
    "@types/node": "^22.0.0",
    "copyfiles": "^2.4.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-mocha": "^11.2.0",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.1.0",
    "husky": "^9.1.7",
    "lerna": "^9.0.0",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "rimraf": "^6.0.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.34.0"
  },
  "engines": {
    "node": ">=22.12.0 || >=20.19.0 <21.0.0"
  }
}
