{
  "name": "jentic-api-scorecard-monorepo",
  "private": true,
  "version": "1.0.0",
  "description": "Workspace root for @jentic/api-scorecard.",
  "license": "Apache-2.0",
  "author": "Jentic <hello@jentic.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jentic/jentic-api-scorecard.git"
  },
  "type": "module",
