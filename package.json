    "packages/*"
  ],
  "scripts": {
    "build": "lerna run build",
    "clean": "lerna run clean",
    "typescript:check-types": "lerna run typescript:check-types",
    "lint": "lerna run lint",
    "lint:fix": "lerna run lint:fix",
    "prepare": "husky"
